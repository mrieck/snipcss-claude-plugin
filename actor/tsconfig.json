{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "./dist",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "baseUrl": ".",
    "paths": {
      "playwright": ["../node_modules/playwright"],
      "playwright-core": ["../node_modules/playwright-core"],
      "playwright-core/*": ["../node_modules/playwright-core/*"]
    }
  },
  "include": ["src/**/*", "../src/**/*"],
  "exclude": ["../node_modules", "../dist", "dist", "node_modules"]
}
