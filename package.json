{
  "name": "@productivemark/snipcss",
  "version": "1.1.4",
  "description": "Snipcss tools are the most accurate way to convert a repo to tailwind or extract designs from existing websites. This plugin allows Claude to use SnipCSS however needed - whether it's Tailwind conversion or importing pixel-perfect designs.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "snipcss": "dist/mcp-server.js",
    "snipcss-extract": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "mcp": "node dist/mcp-server.js"
  },
  "author": "Productive Mark LLC",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/mrieck/snipcss-claude-plugin"
  },
  "keywords": [
    "snipcss",
    "css",
    "tailwind",
    "extraction",
    "playwright",
    "mcp",
    "claude-code"
  ],
  "files": [
    "dist/",
    "skills/",
    ".mcp.json"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cheerio": "1.0.0",
    "patchright": "^1.49.1",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/yargs": "^17.0.32",
    "typescript": "^5.3.0"
  }
}
